# ── GCP ───────────────────────────────────────────────────────────────────────
# ADC = autenticacion con usuario personal via gcloud auth application-default login
# Para Service Account: reemplaza ADC con la ruta al archivo JSON
GCP_CREDENTIALS=ADC

# Proyectos GCP a escanear (separados por coma)
# Para obtener todos los proyectos prj-cf:
# gcloud projects list --format="value(projectId)" | grep "^prj-cf" | tr '\n' ','
GCP_PROJECTS=proyecto-1,proyecto-2,proyecto-3

# ── VCENTER ───────────────────────────────────────────────────────────────────
VCENTER_ENABLED=true

VCENTER_HOST_1=vcenter01.empresa.local
VCENTER_USER_1=svc-inventory@empresa.local
VCENTER_PASS_1=
VCENTER_PORT_1=443

VCENTER_HOST_2=vcenter02.empresa.cloud
VCENTER_USER_2=svc-inventory@empresa.local
VCENTER_PASS_2=
VCENTER_PORT_2=443

# ── OUTPUT ────────────────────────────────────────────────────────────────────
OUTPUT_PATH=output/vm_inventory.xlsx
LOG_PATH=logs/
